# ── Server ──────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave empty to use the defaults (localhost:5173 / 4173 / 3000).
# In production, set this to your deployed frontend URL.
# Example: https://your-app.railway.app,https://your-custom-domain.com
ALLOWED_ORIGINS=

# ── Optional default world path (for quick local testing only) ──────
# Never commit a real .env — world paths are local and sensitive.
DEFAULT_WORLD_PATH=
